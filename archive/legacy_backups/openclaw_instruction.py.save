"""
🦞 OpenClaw 龙虾系统 - 中文版
"""
from fastapi import FastAPI, Form
from fastapi.responses import HTMLResponse, JSONResponse
import uvicorn
import os
import asyncio
import json
import time
from dotenv import load_dotenv
from lobster import call as lobster_call
from data_feed import get_all_data, latest_data

load_dotenv()
app = FastAPI(title="🦞 OpenClaw 龙虾系统")

# 用户偏好配置（默认）
DEFAULT_PREFERENCES = {
    "enabled": False,  # 交易偏好开关，默认关闭
    "risk_level": "medium",
    "max_stop_loss_pct": 2.0,
    "trade_style": "swing",
    "position_size": "medium",
    "preferred_leverage": 1,
    "custom_note": ""
}

def get_preferences():
    try:
        if os.path.exists("preferences.json"):
            with open("preferences.json", "r", encoding="utf-8") as f:
                prefs = json.load(f)
                return {**DEFAULT_PREFERENCES, **prefs}
    except:
        pass
    return DEFAULT_PREFERENCES.copy()

def save_preferences(prefs):
    with open("preferences.json", "w", encoding="utf-8") as f:
        json.dump(prefs, f, ensure_ascii=False, indent=2)

def get_current_price():
    data = get_all_data()
    price = data.get("btc_price", 0)
    return price if price > 0 else latest_data.get("btc_price", 73000.0) or 73000.0

def get_entry_record():
    try:
        if os.path.exists("last_entry.json"):
            with open("last_entry.json", "r", encoding="utf-8") as f:
                return json.load(f)
    except:
        pass
    return None

def save_entry_record(price, side="LONG"):
    entry = {
        "entry_price": price,
        "side": side,
        "time": time.time()
    }
    with open("last_entry.json", "w", encoding="utf-8") as f:
        json.dump(entry, f)
    return entry

def get_reversal_status():
    try:
        if os.path.exists("instruction.log"):
            with open("instruction.log", "r", encoding="utf-8") as f:
                for line in reversed(f.readlines()[-50:]):
                    if "AI_ALERT" in line or "立即平仓" in line:
                        return "警报"
    except:
        pass
    return "正常"

async def check_reversal():
    entry = get_entry_record()
    if not entry:
        return None
    
    entry_price = entry.get("entry_price", 0)
    side = entry.get("side", "LONG")
    current_price = get_current_price()
    prefs = get_preferences()
    max_loss = prefs.get("max_stop_loss_pct", 2.0)
    
    if entry_price == 0 or current_price == 0:
        return None
    
    if side == "LONG":
        pnl_pct = (current_price - entry_price) / entry_price * 100
    else:
        pnl_pct = (entry_price - current_price) / entry_price * 100
    
    if pnl_pct < -max_loss:
        return f"亏损 {pnl_pct:.2f}%"
    
    return None

async def get_ai_decision_with_prefs(price, fear_greed, prefs, entry=None):
    try:
        # 构建基础信息
        # 适配原prefs字段名，映射为中文key（核心兼容改动）
        prefs_mapped = {
            "风险偏好": {
                "low": "保守",
                "medium": "平衡",
                "high": "激进"
            }.get(prefs.get("risk_level", "medium"), "平衡"),
            "交易风格": {
                "scalp": "超短线",
                "day": "日内",
                "swing": "波段",
                "long": "长线"
            }.get(prefs.get("trade_style", "swing"), "波段"),
            "最大止损(%)": prefs.get("max_stop_loss_pct", 2.0),
            "杠杆倍数(x)": prefs.get("preferred_leverage", 1)
        }
        
        # 1. 基础信息
        base_info = f"""
        当前BTC价格：${price:.0f}
        恐惧贪婪指数：{fear_greed}（0-100，越低越恐慌，越高越贪婪）
        用户设置：
        - 风险偏好：{prefs_mapped['风险偏好']}
        - 交易风格：{prefs_mapped['交易风格']}
        - 最大止损：{prefs_mapped['最大止损(%)']}%
        - 杠杆倍数：{prefs_mapped['杠杆倍数(x)']}x
        """
        
        # 2. 核心：自适应多空判断规则（均衡风格）
        direction_logic = """
        【决策规则（必须严格遵守）】
        1. 恐惧贪婪指数 ≤ 30（极度恐慌）→ 优先建议「做多」，止损严格控制在用户设置的0.1%-0.3%
        2. 恐惧贪婪指数 ≥ 70（极度贪婪）→ 优先建议「做空」，止损严格控制在用户设置的0.1%-0.3%
        3. 恐惧贪婪指数 30-70（中性）→ 建议「观望」，不建议开仓
        4. 所有决策必须适配用户设置的100倍杠杆，止损不得超过0.3%、不得低于0.1%
        """
        
        # 3. 输出格式要求（适配现有UI展示）
        output_format = """
        【输出格式（必须严格按此输出）】
        **【决策建议】xxx**（只能是：做多/做空/观望）
        **【入场理由】**
        （1-2句说明判断依据）
        **【风险提示】**
        （1-2句说明当前风险点）
        **【精确点位】**
        *建议入场价：xxx
        *止损价：xxx
        *止盈分批：xxx

⚠️ 注意：这只是AI分析建议，实际交易决策请自行判断！
"""
        
        # 拼接完整提示词（保留持仓信息，兼容原有逻辑）
        position_info = ""
        if entry:
            entry_price = entry.get('entry_price', 0)
            pnl = ((price - entry_price) / entry_price * 100) if entry_price > 0 else 0
            position_info = f"\n当前持仓：{entry.get('side', 'LONG')} @ ${entry_price:,.0f} (盈亏: {pnl:+.2f}%)"
        
        prompt = base_info + position_info + direction_logic + output_format
用中文清晰写出分析结果。"""
        
        loop = asyncio.get_event_loop()
        decision = await asyncio.wait_for(
            loop.run_in_executor(None, lobster_call, prompt),
            timeout=20.0
        )
        return decision
    except:
        return "AI决策超时"

@app.get("/", response_class=HTMLResponse)
async def home():
    prefs = get_preferences()
    btc_price = get_current_price()
    latest_data["btc_price"] = btc_price
    fear_greed = latest_data.get("fear_greed", 50)
    
    entry = get_entry_record()
    decision = await get_ai_decision_with_prefs(btc_price, fear_greed, prefs, entry)
    reversal = await check_reversal()
    reversal_status = reversal if reversal else "正常"
    
    # 入场盈亏计算
    pnl_html = ""
    if entry:
        entry_price = entry.get('entry_price', 0)
        pnl = ((btc_price - entry_price) / entry_price * 100) if entry_price > 0 else 0
        pnl_color = "#10a37f" if pnl >= 0 else "#ef4146"
        pnl_sign = "+" if pnl >= 0 else ""
        pnl_html = f'<span style="color: {pnl_color}; font-weight: 600;">{pnl_sign}{pnl:.2f}%</span>'
    
    # 情绪中文
    if fear_greed < 30:
        sentiment_color = "#ef4146"
        sentiment_text = "极度恐慌"
    elif fear_greed < 50:
        sentiment_color = "#f59e0b"
        sentiment_text = "恐慌"
    elif fear_greed < 70:
        sentiment_color = "#10a37f"
        sentiment_text = "贪婪"
    else:
        sentiment_color = "#ef4146"
        sentiment_text = "极度贪婪"
    
    # 风险偏好中文
    risk_cn = {"low": "保守", "medium": "平衡", "high": "激进"}.get(prefs.get("risk_level"), "平衡")
    style_cn = {"scalp": "超短线", "day": "日内", "swing": "波段", "long": "长线"}.get(prefs.get("trade_style"), "波段")
    
    # 用于 JavaScript 的当前价格
    current_price = f"{btc_price:.2f}"
    
    html = f"""
    <!DOCTYPE html>
    <html lang="zh-CN">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta http-equiv="refresh" content="30">
        <title>OpenClaw - AI交易助手</title>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
        <style>
            * {{
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }}
            
            body {{
                font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
                background: #ffffff;
                color: #374151;
                line-height: 1.6;
            }}
            
            /* Header */
            .header {{
                background: #ffffff;
                border-bottom: 1px solid #e5e7eb;
                padding: 16px 24px;
                position: sticky;
                top: 0;
                z-index: 100;
            }}
            
            .header-content {{
                max-width: 1200px;
                margin: 0 auto;
                display: flex;
                align-items: center;
                justify-content: space-between;
            }}
            
            .logo {{
                display: flex;
                align-items: center;
                gap: 12px;
                font-size: 20px;
                font-weight: 700;
                color: #111827;
            }}
            
            .logo-icon {{
                font-size: 28px;
            }}
            
            .status-badge {{
                display: flex;
                align-items: center;
                gap: 8px;
                padding: 6px 12px;
                background: #f3f4f6;
                border-radius: 20px;
                font-size: 13px;
                font-weight: 500;
                color: #6b7280;
            }}
            
            .status-dot {{
                width: 8px;
                height: 8px;
                background: #10a37f;
                border-radius: 50%;
                animation: pulse 2s infinite;
            }}
            
            @keyframes pulse {{
                0%, 100% {{ opacity: 1; }}
                50% {{ opacity: 0.5; }}
            }}
            
            /* Main Container */
            .container {{
                max-width: 900px;
                margin: 0 auto;
                padding: 32px 24px;
            }}
            
            /* Price Card */
            .price-card {{
                background: linear-gradient(135deg, #111827 0%, #1f2937 100%);
                border-radius: 16px;
