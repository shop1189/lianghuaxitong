def _zh_decision_copy(text: object) -> str:
    """将决策文案中的周期缩写改为中文，便于阅读（不改变数值与 RSI 等术语）。"""
    s = str(text or "")
    if not s:
        return s
    s = s.replace("1H+4H", "1小时+4小时")
    for a, b in (
        ("5m=", "5分钟="),
        ("15m=", "15分钟="),
        ("1H=", "1小时="),
        ("4H=", "4小时="),
    ):
        s = s.replace(a, b)
    s = s.replace(" | ", " · ")
    s = s.replace("RSI(1m)", "RSI（1分钟）")
    return s


def _reflection_suggestion(rep: dict) -> str:
    if rep.get("status") == "waiting":
        return "系统持续收集 memos 样本中，建议保持观察并等待足够平仓统计后再调参。"
    try:
        wr = float(rep.get("总胜率", 0))
    except Exception:
        wr = 0.0
    if wr >= 55:
        return "样本总胜率偏高，注意过拟合；可适度收紧开仓条件或拉长冷却间隔。"
    if wr >= 45:
        return "胜率处于中性区间，建议继续积累 memos 样本，并观察多空分布与时段规律。"
    return "近期胜率偏低，建议结合大周期趋势与冷却节奏，避免在震荡区间反复试错。"


