def fmt_price(v) -> str:
    if v is None:
        return "—"
    try:
        return f"{float(v):.6f}".rstrip("0").rstrip(".")
    except Exception:
        return "—"


def fmt_vol(v) -> str:
    if v is None:
        return "—"
    try:
        return f"{float(v):.4f}"
    except Exception:
        return "—"


def json_dumps_safe(obj) -> str:
    try:
        return json.dumps(obj, ensure_ascii=False, indent=2)
    except Exception:
        return str(obj)


