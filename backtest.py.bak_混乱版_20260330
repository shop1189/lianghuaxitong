def build_1m_feature_table(df_1m: pd.DataFrame, idx_5m: pd.DatetimeIndex) -> pd.DataFrame:
    feat = pd.DataFrame(index=df_1m.index)
    feat["close"] = df_1m["Close"]
    feat["atr1m"] = ta.atr(df_1m["High"], df_1m["Low"], df_1m["Close"], 14).bfill().fillna(0)
    feat["ema13"] = ema(df_1m["Close"], 13)
    feat["ema21"] = ema(df_1m["Close"], 21)
    feat["trend_up"] = feat["ema13"] > feat["ema21"]
    feat["trend_dn"] = feat["ema13"] < feat["ema21"]
    feat["rsi"] = rsi(df_1m["Close"], 14).fillna(50)
    feat["rsi_ta"] = ta.rsi(df_1m["Close"], length=14).fillna(50)
    # 第13步：短周期 EMA5/EMA13 预计算（与 ta.ema 一致；_TACompat 无 ema 时用 indicator_upgrade.ema）
    if hasattr(ta, "ema"):
        feat["ema_fast_1m"] = ta.ema(df_1m["Close"], length=5).bfill().fillna(0)
        feat["ema_slow_1m"] = ta.ema(df_1m["Close"], length=13).bfill().fillna(0)
    else:
        feat["ema_fast_1m"] = ema(df_1m["Close"], 5).bfill().fillna(0)
        feat["ema_slow_1m"] = ema(df_1m["Close"], 13).bfill().fillna(0)
    # 第14步：新增 BB 中轨确认滤波（提升 PF 同时尽量保笔数）
    # BB length=20 std=2，close > bb_middle 为 long（趋势中轨上确认），预计日均仍8笔左右
    if hasattr(ta, "bbands"):
        bb = ta.bbands(df_1m["Close"], length=20, std=2)
        if isinstance(bb, pd.DataFrame) and len(bb.columns) > 0:
            mid_col = "BBM_20_2.0" if "BBM_20_2.0" in bb.columns else next(
                (c for c in bb.columns if str(c).startswith("BBM")), None
            )
            feat["bb_middle_1m"] = bb[mid_col].bfill().fillna(0) if mid_col else df_1m["Close"].rolling(20).mean().bfill().fillna(0)
        else:
            feat["bb_middle_1m"] = df_1m["Close"].rolling(20).mean().bfill().fillna(0)
    else:
        feat["bb_middle_1m"] = df_1m["Close"].rolling(20).mean().bfill().fillna(0)
    if hasattr(ta, "adx") and "High" in df_1m.columns:
        adx = ta.adx(df_1m["High"], df_1m["Low"], df_1m["Close"], length=14)
        if isinstance(adx, pd.DataFrame) and adx is not None and "ADX_14" in adx.columns:
            feat["adx_1m"] = adx["ADX_14"].bfill().fillna(0)
        elif isinstance(adx, pd.DataFrame) and len(adx.columns) > 0:
            adx_col = next((c for c in adx.columns if str(c).startswith("ADX_")), None)
            feat["adx_1m"] = adx[adx_col].bfill().fillna(0) if adx_col else df_1m["Close"].rolling(14).mean().bfill().fillna(0)
        else:
            feat["adx_1m"] = df_1m["Close"].rolling(14).mean().bfill().fillna(0)
    else:
        feat["adx_1m"] = df_1m["Close"].rolling(14).mean().bfill().fillna(0)
    # 第21步：反转检测用 1m EMA5/13 + RSI（与 ta 一致；无 ta.ema 时用 indicator_upgrade.ema）
    if hasattr(ta, "ema"):
        feat["ema5_1m"] = ta.ema(df_1m["Close"], length=5).bfill().fillna(0)
        feat["ema13_1m"] = ta.ema(df_1m["Close"], length=13).bfill().fillna(0)
    else:
        feat["ema5_1m"] = ema(df_1m["Close"], 5).bfill().fillna(0)
        feat["ema13_1m"] = ema(df_1m["Close"], 13).bfill().fillna(0)
    feat["rsi_1m"] = ta.rsi(df_1m["Close"], length=14).fillna(50) if hasattr(ta, "rsi") else rsi(df_1m["Close"], 14).fillna(50)
    feat["atr_1m"] = feat["atr1m"]
    # 第23步：20 期 EMA（保留列，供分析/兼容）
    if hasattr(ta, "ema"):
        feat["ema20_1m"] = ta.ema(df_1m["Close"], length=20).bfill().fillna(0)
    else:
        feat["ema20_1m"] = ema(df_1m["Close"], 20).bfill().fillna(0)
    # 第24步：50 期 EMA 用于「明确突破」入场（更强趋势过滤）
    if hasattr(ta, "ema"):
        feat["ema50_1m"] = ta.ema(df_1m["Close"], length=50).bfill().fillna(0)
    else:
        feat["ema50_1m"] = ema(df_1m["Close"], 50).bfill().fillna(0)
    feat["volume"] = df_1m["Volume"].astype(float)
    vol_series = feat["volume"]
    if hasattr(ta, "sma"):
        vol_ma_s = ta.sma(vol_series, length=20)
        if not isinstance(vol_ma_s, pd.Series):
            vol_ma_s = pd.Series(vol_ma_s, index=df_1m.index, dtype=float)
        feat["vol_ma_1m"] = vol_ma_s.bfill().fillna(0)
    else:
        feat["vol_ma_1m"] = vol_series.rolling(20).mean().bfill().fillna(0)
    macd_ta = ta.macd(df_1m["Close"], fast=12, slow=26, signal=9)
    feat["macd_ta"] = macd_ta["MACD_12_26_9"].fillna(0)
    feat["macd_signal_ta"] = macd_ta["MACDs_12_26_9"].fillna(0)
    feat["macd_hist_ta"] = macd_ta["MACDh_12_26_9"].fillna(0)
    feat["macd_ta_prev"] = feat["macd_ta"].shift(1).fillna(0)
    feat["macd_signal_ta_prev"] = feat["macd_signal_ta"].shift(1).fillna(0)

    up3 = (df_1m["Close"] > df_1m["Close"].shift(1)) & (df_1m["Close"].shift(1) > df_1m["Close"].shift(2))
    dn3 = (df_1m["Close"] < df_1m["Close"].shift(1)) & (df_1m["Close"].shift(1) < df_1m["Close"].shift(2))
    feat["pattern_score"] = np.where(up3, 1, np.where(dn3, -1, 0))

    prev_h = df_1m["High"].rolling(10).max().shift(1)
    prev_l = df_1m["Low"].rolling(10).min().shift(1)
    breakout = (df_1m["Close"] > prev_h) | (df_1m["Close"] < prev_l)
    pullback = ((df_1m["Close"] - feat["ema21"]).abs() / (df_1m["Close"] + 1e-12)) < 0.0012
    feat["entry_mode_hint"] = np.where(breakout, 1, np.where(pullback, -1, 0))

    # map 1m features to 5m bars (use last known minute)
    mapped = feat.reindex(idx_5m, method="ffill").fillna(0)
    return mapped


def gene_signal(feat_row, gene):
    # 1m精确入场（每天3-8笔） + 5m趋势参考
    trend_up = bool(
        (feat_row["ema13_1m"] > feat_row["ema21_1m"])
        and (feat_row["trend_5m_up"] or feat_row["trend_1h_up"])
    )
    trend_dn = bool(
        (feat_row["ema13_1m"] < feat_row["ema21_1m"])
        and (feat_row["trend_5m_dn"] or feat_row["trend_1h_dn"])
    )
    rsi_long_ok = 30 < float(feat_row["rsi5"]) < 65
    rsi_short_ok = 35 < float(feat_row["rsi5"]) < 70
    macd_expand_up = float(feat_row["hist"]) > 0 and float(feat_row["hist"]) > float(feat_row["hist_prev"])
    macd_expand_dn = float(feat_row["hist"]) < 0 and float(feat_row["hist"]) < float(feat_row["hist_prev"])

    pattern_long = feat_row["pattern_score"] > 0
    pattern_short = feat_row["pattern_score"] < 0
    vol_expand = bool(feat_row["vol_expand"])

    # gene mode
    use_breakout = getattr(gene, "breakout_bias", 0.5) >= getattr(gene, "pullback_bias", 0.5)
    mode_long = bool(feat_row["breakout_up"]) if use_breakout else bool(feat_row["pullback_long"])
    mode_short = bool(feat_row["breakout_dn"]) if use_breakout else bool(feat_row["pullback_short"])

    pattern_gate_long = pattern_long or vol_expand or (feat_row["pattern_score"] >= 0)
    pattern_gate_short = pattern_short or vol_expand or (feat_row["pattern_score"] <= 0)
    # 第10步：资金面过滤关闭（无过滤）
    factor_gate_long = True
    factor_gate_short = True

    long_sig = trend_up and rsi_long_ok and macd_expand_up and pattern_gate_long and mode_long and factor_gate_long
    short_sig = trend_dn and rsi_short_ok and macd_expand_dn and pattern_gate_short and mode_short and factor_gate_short
    if long_sig:
        return 1
    if short_sig:
        return -1
    return 0


def evaluate_gene(gene, feat: pd.DataFrame, start: int, end: int):
    pnl = 0.0
    wins = 0
    losses = 0
    pos = 0
    entry = 0.0
    for i in range(start, end):
        row = feat.iloc[i]
        price = float(row["close"])
        high = float(row["high"])
        low = float(row["low"])
        if pos == 0:
            sig = gene_signal(row, gene)
            if sig != 0:
                pos = sig
                entry = price
        else:
            if pos == 1:
                sl = entry * (1 - STOP_LOSS_PCT)
                tp = entry * (1 + TAKE_PROFIT_PCT)
                if low <= sl:
                    p = (sl / entry - 1)
                    pnl += p
                    losses += 1
                    pos = 0
                elif high >= tp:
                    p = (tp / entry - 1)
                    pnl += p
                    wins += 1
                    pos = 0
            else:
                sl = entry * (1 + STOP_LOSS_PCT)
                tp = entry * (1 - TAKE_PROFIT_PCT)
                if high >= sl:
                    p = (entry / sl - 1)
                    pnl += p
                    losses += 1
                    pos = 0
                elif low <= tp:
                    p = (entry / tp - 1)
                    pnl += p
                    wins += 1
                    pos = 0
    trades = wins + losses
    win_rate = (wins / trades * 100) if trades else 0.0
    score = pnl * 100 + win_rate * 0.2
    score_gene(gene, score)
    return score, trades, win_rate


def evolve_genes(feat: pd.DataFrame, generations=SIM_GENERATIONS):
    arena = Arena()
    genes = arena.run()
    if genes is None or len(genes) == 0:
        genes = [StrategyGene(1, "fallback", "stable")]

    window = max(200, len(feat) // (generations + 2))
    for g in range(generations):
        start = g * window
        end = min(len(feat), start + window)
        for gene in genes:
            evaluate_gene(gene, feat, start, end)
        genes = sorted(genes, key=lambda x: getattr(x, "score", 0), reverse=True)
        best = genes[0]
        weakest = genes[-1]
        weakest.is_active = False
        new_id = max(getattr(x, "strategy_id", i + 1) for i, x in enumerate(genes)) + 1
        child = mutate_from_best(best, new_id)
        inherit_direction(child, getattr(best, "direction", "观望"))
        genes.append(child)
        genes = sorted([x for x in genes if getattr(x, "is_active", True)], key=lambda x: getattr(x, "score", 0), reverse=True)[:6]
    genes = sorted(genes, key=lambda x: getattr(x, "score", 0), reverse=True)
    return genes[0]


