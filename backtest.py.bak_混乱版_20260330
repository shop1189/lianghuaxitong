except Exception:
    class _TACompat:
        @staticmethod
        def atr(high, low, close, length=14):
            high = pd.Series(high, dtype=float)
            low = pd.Series(low, dtype=float)
            close = pd.Series(close, dtype=float)
            prev_close = close.shift(1)
            tr = pd.concat(
                [(high - low), (high - prev_close).abs(), (low - prev_close).abs()],
                axis=1,
            ).max(axis=1)
            return tr.rolling(length).mean()

        @staticmethod
        def rsi(close, length=14):
            close = pd.Series(close, dtype=float)
            delta = close.diff()
            gain = delta.where(delta > 0, 0.0).rolling(length).mean()
            loss = (-delta.where(delta < 0, 0.0)).rolling(length).mean()
            rs = gain / loss.replace(0, np.nan)
            out = 100 - (100 / (1 + rs))
            return out.fillna(50.0)

        @staticmethod
        def macd(close, fast=12, slow=26, signal=9):
            close = pd.Series(close, dtype=float)
            ema_fast = close.ewm(span=fast, adjust=False).mean()
            ema_slow = close.ewm(span=slow, adjust=False).mean()
            macd_line = ema_fast - ema_slow
            macd_signal = macd_line.ewm(span=signal, adjust=False).mean()
            macd_hist = macd_line - macd_signal
            return pd.DataFrame(
                {
                    f"MACD_{fast}_{slow}_{signal}": macd_line,
                    f"MACDs_{fast}_{slow}_{signal}": macd_signal,
                    f"MACDh_{fast}_{slow}_{signal}": macd_hist,
                }
            )

    ta = _TACompat()
