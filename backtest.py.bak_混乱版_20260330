def fetch_ohlcv_ccxt(limit: int = LIMIT) -> pd.DataFrame:
    exchange = ccxt.binance({"enableRateLimit": True})
    since = exchange.milliseconds() - (365 * 24 * 60 * 60 * 1000)
    all_rows = []
    while len(all_rows) < limit:
        batch = exchange.fetch_ohlcv(SYMBOL, timeframe=TIMEFRAME, since=since, limit=1000)
        if not batch:
            break
        all_rows.extend(batch)
        since = batch[-1][0] + 1
        if len(batch) < 1000:
            break
    all_rows = all_rows[-limit:]
    if len(all_rows) < 500:
        raise RuntimeError(f"historical data too short: {len(all_rows)} rows")
    df = pd.DataFrame(all_rows, columns=["timestamp", "Open", "High", "Low", "Close", "Volume"])
    df["Date"] = pd.to_datetime(df["timestamp"], unit="ms", utc=True)
    df = df.set_index("Date")[["Open", "High", "Low", "Close", "Volume"]].astype(float)
    return df


def build_feature_table(df: pd.DataFrame) -> pd.DataFrame:
    tf = get_multi_tf_data(use_live=False, base_df=df)
    feat = pd.DataFrame(index=df.index)
    feat["close"] = df["Close"]
    feat["high"] = df["High"]
    feat["low"] = df["Low"]
    # 1m main signal on execution timeframe
    feat["ema13_1m"] = ema(df["Close"], 13)
    feat["ema21_1m"] = ema(df["Close"], 21)
    feat["rsi5"] = rsi(df["Close"], 14).fillna(50)
    feat["rsi_ta"] = ta.rsi(df["Close"], length=14).fillna(50)
    macd_ta = ta.macd(df["Close"], fast=12, slow=26, signal=9)
    feat["macd_ta"] = macd_ta["MACD_12_26_9"].fillna(0)
    feat["macd_signal_ta"] = macd_ta["MACDs_12_26_9"].fillna(0)
    feat["macd_hist_ta"] = macd_ta["MACDh_12_26_9"].fillna(0)
    _, _, hist = macd(df["Close"])
    feat["hist"] = hist.fillna(0)
    feat["hist_prev"] = feat["hist"].shift(1).fillna(0)

    e13_5m = ema(tf["5m"]["Close"], 13)
    e21_5m = ema(tf["5m"]["Close"], 21)
    e13_1h = ema(tf["1h"]["Close"], 13)
    e21_1h = ema(tf["1h"]["Close"], 21)
    feat["trend_5m_up"] = (e13_5m > e21_5m).reindex(df.index, method="ffill").fillna(False)
    feat["trend_5m_dn"] = (e13_5m < e21_5m).reindex(df.index, method="ffill").fillna(False)
    feat["trend_1h_up"] = (e13_1h > e21_1h).reindex(df.index, method="ffill").fillna(False)
    feat["trend_1h_dn"] = (e13_1h < e21_1h).reindex(df.index, method="ffill").fillna(False)

    ret = df["Close"].pct_change().fillna(0.0)
    volz = (df["Volume"] - df["Volume"].rolling(120).mean()) / df["Volume"].rolling(120).std().replace(0, np.nan)
    volz = volz.fillna(0.0)
    feat["taker_buy"] = (0.5 + np.tanh(ret * 120 + volz * 0.15) * 0.08).clip(0.35, 0.65)
    feat["ls_ratio"] = (1.0 + np.tanh(ret.rolling(6).sum().fillna(0) * 50) * 0.35).clip(0.6, 1.4)
    feat["funding"] = (ret.rolling(12).mean().fillna(0) * 8).clip(-0.001, 0.001)
    feat["oi_bias"] = np.tanh(volz * 0.4 + ret.rolling(3).sum().fillna(0) * 30)

    rolling_high = df["High"].rolling(20).max().shift(1)
    rolling_low = df["Low"].rolling(20).min().shift(1)
    feat["breakout_up"] = feat["close"] > rolling_high
    feat["breakout_dn"] = feat["close"] < rolling_low
    feat["pullback_long"] = (feat["low"] <= feat["ema21_1m"]) & (feat["close"] >= feat["ema21_1m"])
    feat["pullback_short"] = (feat["high"] >= feat["ema21_1m"]) & (feat["close"] <= feat["ema21_1m"])

    # fast pattern/volume cache (vectorized surrogate)
    up3 = (df["Close"] > df["Close"].shift(1)) & (df["Close"].shift(1) > df["Close"].shift(2))
    dn3 = (df["Close"] < df["Close"].shift(1)) & (df["Close"].shift(1) < df["Close"].shift(2))
    feat["pattern_score"] = np.where(up3, 1, np.where(dn3, -1, 0))
    vol_ma = df["Volume"].rolling(20).mean()
    feat["vol_expand"] = (df["Volume"] > vol_ma * 1.15).fillna(False)
    feat = feat.ffill().fillna(0)
    return feat


