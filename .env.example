# Copy to `.env` and fill in locally. Do NOT commit `.env`.
# After any key was pasted in chat/email, rotate it at the provider.

# --- Binance (read-only; futures WS e.g. liquidations / public signed REST) ---
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Gate.io APIv4 (spot and/or futures read-only; separate key pairs per Gate console) ---
LONGXIA_GATE_API_KEY=
LONGXIA_GATE_API_SECRET=

# --- Optional third-party ---
COINGLASS_API_KEY=
CRYPTOQUANT_API_TOKEN=

# --- Fear & Greed (no key; override URL if needed) ---
FEAR_GREED_API_URL=https://api.alternative.me/fng/

# --- LunarCrush (optional social metrics) ---
LUNARCRUSH_API_KEY=
