# 回测参数网格模板（净收益优先）
# 用法：回测脚本逐组 source 本文件中的组合，输出净收益排序。
# 注意：这些是“起始网格”，不是固定最优值。

# 成本口径（必须和线上一致）
LONGXIA_FEE_ROUNDTRIP_PCT=0.16
LONGXIA_SLIPPAGE_PCT=0.02

# 信号质量门（先抑制噪音单）
LONGXIA_EXPERIMENT_REQUIRE_STRONG=1
LONGXIA_EXPERIMENT_MIN_SCORE_ABS=0.35,0.42,0.50
LONGXIA_KRONOS_MIN_PROB_EDGE=4,6,8

# 状态分档阈值（chop 收紧）
LONGXIA_EXPERIMENT_EDGE_CHOP_EXTRA=2,3,4
LONGXIA_EXPERIMENT_SCORE_CHOP_FLOOR=0.55,0.60,0.65

# 风险收益结构（避免高胜率低净利）
LONGXIA_EXPERIMENT_SL_PCT=0.007,0.008,0.009
LONGXIA_EXPERIMENT_TP1_PCT=0.004,0.005
LONGXIA_EXPERIMENT_TP2_PCT=0.010,0.012
LONGXIA_EXPERIMENT_TP3_PCT=0.016,0.018

# 波动过滤（低波动不做）
LONGXIA_EXPERIMENT_ATR_MIN_PCT=0.022,0.028,0.035

# Coinglass 微调（与线上一致）
LONGXIA_COINGLASS_SCORE_ENABLE=1
LONGXIA_COINGLASS_INTERVAL=4h
LONGXIA_COINGLASS_OI_THRESH_PCT=1.2,1.8
LONGXIA_COINGLASS_FR_THRESH=0.00020,0.00035
LONGXIA_COINGLASS_LIQ_BIAS_THRESH=0.30,0.45
LONGXIA_COINGLASS_DELTA_CAP=0.05,0.065

# 币安微调（与线上一致）
LONGXIA_BINANCE_SCORE_ENABLE=1
LONGXIA_BINANCE_SCORE_DELTA_CAP=0.045,0.055

# 输出考核（按净口径排序）
# 1) net_pnl_pct
# 2) expectancy_net
# 3) max_drawdown
# 4) trades_count (过滤样本过少)
