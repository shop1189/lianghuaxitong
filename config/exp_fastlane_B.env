# 矩阵「日课 B」阈值见 config/backtest_matrix_daily_B.env（与云端签收 A/B 的 B 组一致）。
# fastlane / 回测：LONGXIA_HTTP_PORT=8080，与主进程默认 18080（Phase-1 Web）并行、不抢端口
LONGXIA_EXPERIMENT_MODE=kronos_light
LONGXIA_EXPERIMENT_TRACK=1
LONGXIA_HTTP_PORT=8080
LONGXIA_KRONOS_MIN_PROB_EDGE=7
LONGXIA_EXPERIMENT_MIN_SCORE_ABS=0.55
LONGXIA_EXPERIMENT_DAY_STOP_PCT=-0.8
