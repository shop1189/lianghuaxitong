# fastlane / 回测：LONGXIA_HTTP_PORT=8080，与主进程默认 18080（Phase-1 Web）并行、不抢端口
LONGXIA_EXPERIMENT_MODE=kronos_light
LONGXIA_EXPERIMENT_TRACK=1
LONGXIA_HTTP_PORT=8080
# 与 live_trading.py 实验轨默认「采样偏松」对齐；要收紧可改大下面两项
LONGXIA_KRONOS_MIN_PROB_EDGE=2
LONGXIA_EXPERIMENT_MIN_SCORE_ABS=0.28
LONGXIA_EXPERIMENT_DAY_STOP_PCT=-1.0
